-secondary mb-8","children":"Last updated: March 2026"}],["$","div",null,{"className":"space-y-8 text-text-secondary","children":[["$","section",null,{"children":[["$","h2",null,{"className":"text-xl font-semibold text-white mb-4","children":"1. Information We Collect"}],["$","p",null,{"className":"mb-4","children":"Canine.Fit collects the following information to provide our dog healthspan tracking services:"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Account Information:"}]," Name, email address, and password (hashed via Supabase Auth)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Dog Profiles:"}]," Name, breed, date of birth, weight, sex, and activity level"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Health Data:"}]," Daily mood, exercise level, nutrition quality, and notes you log"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Photos:"}]," Optional dog photos for mood analysis (processed by AI, not stored permanently)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Payment Information:"}]," Processed securely via Stripe - we never store card numbers"]}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-xl font-semibold text-white mb-4","children":"2. How We Use Your Information"}],["$","ul",null,{"className":"list-disc pl-6 space-y-2","children":[["$","li",null,{"children":"Provide personalized healthspan tracking and AI insights for your dog"}],["$","li",null,{"children":"Generate breed-specific leaderboards and comparisons"}],["$","li",null,{"children":"Process subscription payments and manage your account"}],["$","li",null,{"children":"Send important updates about your account and our services"}],["$","li",null,{"children":"Improve our AI models and service quality (anonymized data)"}]]}]]}],["$","section",null,{"children":[["$","h2",null,{"className":"text-xl font-semibold text-whi